# Copy to .env.verify and fill in. Used by docker-compose.verify.yaml.

# --- Agent LLM auth (provide ONE) ---
# From `claude setup-token` on a trusted machine (works headless, no API key):
CLAUDE_CODE_OAUTH_TOKEN=
# OR an Anthropic-compatible API key (+ base url if using a gateway):
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# Model (provider-qualified if pointing at a non-Anthropic gateway):
SLAUDE_MODEL=claude-sonnet-4-6

# --- grafana stdio MCP (from ../deploy-hermes/agents/maria/.env) ---
GRAFANA_URL=
GRAFANA_API_KEY=

# workbench (the MCP under test) needs NO key here — it authenticates via MCP OAuth,
# which the claude-code child persists under CLAUDE_CONFIG_DIR (/data/.claude).
