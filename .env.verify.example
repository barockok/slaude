# Copy to .env.verify and fill in. Used by docker-compose.verify.yaml.

# --- Agent LLM auth (provide ONE scheme) ---
# A) Anthropic subscription (headless, no key): from `claude setup-token`
CLAUDE_CODE_OAUTH_TOKEN=
# B) Anthropic API key OR an Anthropic-compatible GATEWAY (Kimi, OpenRouter, …):
#    put the gateway token in ANTHROPIC_API_KEY (sent as x-api-key) and set the
#    gateway base url. slaude reads SLAUDE_MODEL — set it to the GATEWAY's model
#    id, not a claude-* id, or the gateway rejects the request.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# Model. Anthropic → claude-sonnet-4-6. Gateway → the gateway's model id.
SLAUDE_MODEL=claude-sonnet-4-6

# --- grafana stdio MCP (from ../deploy-hermes/agents/maria/.env) ---
GRAFANA_URL=
GRAFANA_API_KEY=

# workbench (the MCP under test) needs NO key here — it authenticates via MCP OAuth,
# which the claude-code child persists under CLAUDE_CONFIG_DIR (/data/.claude).

# /mcp OAuth loopback (container): bind 0.0.0.0 and pre-map this range with docker -p.
SLAUDE_OAUTH_LOOPBACK_HOST=0.0.0.0
SLAUDE_OAUTH_LOOPBACK_PORTS=40100-40110
