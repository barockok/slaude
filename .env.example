# slaude environment — copy to .env and fill in.

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Engagement gate (manager / allowedChannels) lives in SOUL.md, not env.
# In non-whitelisted channels and DMs, only the SOUL.md manager engages.
# In whitelisted channels (## Allowed channels), anyone may address the bot.

# Comma-separated Slack user IDs allowed to click Approve / Deny on
# mcp__slaude_slack__request_approval plans. Only used as a fallback when
# SOUL.md has no `## Approvers` section. Empty = any clicker accepted.
SLAUDE_APPROVERS=

# --- LLM provider (any Anthropic-compatible API) ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional: point at any compatible gateway (OpenRouter, Z.ai, self-hosted, etc.)
# ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1
# Some gateways prefer a bearer token instead of x-api-key.
# ANTHROPIC_AUTH_TOKEN=...
# Provider-qualified model id.
SLAUDE_MODEL=claude-sonnet-4-6

# --- Tool approval ---
# Comma-separated tool names auto-allowed without prompting in Slack.
# Other tools post a Block Kit Allow / Always / Deny prompt to the thread.
# Empty = ask for every tool.
SLAUDE_AUTO_ALLOW_TOOLS=Read,Grep,Glob,LS

# Default permission mode for new sessions. Override per-thread with /mode.
#   ask          — prompt per tool (default)
#   accept-edits — auto-allow Read/Write/Edit; still ask for Bash etc.
#   bypass       — YOLO; every tool auto-allowed
#   plan         — planning only; no tool execution
#   dont-ask     — deny anything not pre-approved
SLAUDE_DEFAULT_MODE=ask

# Idle timeout in minutes. Session's SDK Query closes after this much
# inactivity; next inbound message in the same thread resumes via SDK
# `resume` flag. Default 15. Set to 0 to disable.
SLAUDE_IDLE_MINUTES=15

# Health server port. Exposes /healthz (liveness) + /readyz (DB ping).
# Set to 0 to disable. Default 8080.
SLAUDE_HEALTH_PORT=8080
