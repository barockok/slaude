# slaude environment — copy to .env and fill in.

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
# Comma-separated Slack user IDs allowed to talk to the bot. Empty = anyone.
SLACK_ALLOWED_USERS=

# --- LLM provider (any Anthropic-compatible API) ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional: point at any compatible gateway (OpenRouter, Z.ai, self-hosted, etc.)
# ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1
# Some gateways prefer a bearer token instead of x-api-key.
# ANTHROPIC_AUTH_TOKEN=...
# Provider-qualified model id.
SLAUDE_MODEL=claude-sonnet-4-6

# --- Tool approval ---
# Comma-separated tool names auto-allowed without prompting in Slack.
# Other tools post a Block Kit Allow / Always / Deny prompt to the thread.
# Empty = ask for every tool.
SLAUDE_AUTO_ALLOW_TOOLS=Read,Grep,Glob,LS

# Default permission mode for new sessions. Override per-thread with /mode.
#   ask          — prompt per tool (default)
#   accept-edits — auto-allow Read/Write/Edit; still ask for Bash etc.
#   bypass       — YOLO; every tool auto-allowed
#   plan         — planning only; no tool execution
#   dont-ask     — deny anything not pre-approved
SLAUDE_DEFAULT_MODE=ask
