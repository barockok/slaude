# slaude environment — copy to .env and fill in.

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Engagement gate (manager / allowedChannels) lives in SOUL.md, not env.
# In non-whitelisted channels and DMs, only the SOUL.md manager engages.
# In whitelisted channels (## Allowed channels), anyone may address the bot.

# Comma-separated Slack user IDs allowed to click Approve / Deny on
# mcp__slaude_slack__request_approval plans. Only used as a fallback when
# SOUL.md has no `## Approvers` section. Empty = any clicker accepted.
SLAUDE_APPROVERS=

# --- LLM provider (any Anthropic-compatible API) ---
# Pick ONE of the two auth modes below.
#
# (a) API key — works with Anthropic + any compatible gateway.
ANTHROPIC_API_KEY=sk-ant-...
# (b) Claude Pro / Max subscription OAuth token. Generate with `claude setup-token`
#     on a machine that's already logged into Claude Code, then paste here. The
#     SDK child + the soul extractor both auto-detect. Useful when you want to
#     run slaude on your Claude subscription instead of metered API credits.
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
#
# Optional: point at any compatible gateway (OpenRouter, Z.ai, self-hosted, etc.)
# ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1
# Some gateways prefer a bearer token instead of x-api-key.
# ANTHROPIC_AUTH_TOKEN=...
# Model override. Leave UNSET to let Claude Code's SDK / CLI pick its own
# default (recommended with CLAUDE_CODE_OAUTH_TOKEN — inherits the
# subscription default model). REQUIRED when ANTHROPIC_BASE_URL points at a
# non-Anthropic gateway (OpenRouter, Z.ai, self-hosted) — those endpoints
# don't recognise Anthropic's default model id, so you must remap to a
# provider-qualified id.
# Wins over ANTHROPIC_MODEL (below) when both are set.
# SLAUDE_MODEL=claude-sonnet-4-6
#
# Claude Code CLI also honours its own model env vars — slaude forwards
# all parent env to the SDK child, so these flow through transparently:
#
#   ANTHROPIC_MODEL              fallback main-session model when SLAUDE_MODEL
#                                is unset. Same semantics, just CLI-native.
#   ANTHROPIC_SMALL_FAST_MODEL   haiku-class model for compaction, tool
#                                routing, and sub-tasks. Orthogonal to the
#                                main model; pin explicitly only if you want
#                                a non-default fast-tier.
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_SMALL_FAST_MODEL=claude-haiku-4-5
#
# Note: there is NO per-tier env var (e.g. ANTHROPIC_OPUS_MODEL /
# ANTHROPIC_SONNET_MODEL). Only the two above are CLI-native.

# --- Tool approval ---
# Comma-separated tool names auto-allowed without prompting in Slack.
# Other tools post a Block Kit Allow / Always / Deny prompt to the thread.
# Empty = ask for every tool.
SLAUDE_AUTO_ALLOW_TOOLS=Read,Grep,Glob,LS

# Default permission mode for new sessions. Override per-thread with /mode.
#   ask          — prompt per tool (default)
#   accept-edits — auto-allow Read/Write/Edit; still ask for Bash etc.
#   bypass       — YOLO; every tool auto-allowed
#   plan         — planning only; no tool execution
#   dont-ask     — deny anything not pre-approved
SLAUDE_DEFAULT_MODE=ask

# Idle timeout in minutes. Session's SDK Query closes after this much
# inactivity; next inbound message in the same thread resumes via SDK
# `resume` flag. Default 15. Set to 0 to disable.
SLAUDE_IDLE_MINUTES=15

# Health server port. Exposes /healthz (liveness) + /readyz (DB ping).
# Set to 0 to disable. Default 8080.
SLAUDE_HEALTH_PORT=8080

# --- Context budget ---
# Fraction of the model's context window (sourced live from the SDK's
# ModelUsage.contextWindow) at which slaude posts a one-shot warning /
# critical notice in the active Slack thread. Edge-triggered: each level
# fires once per session. Set the critical pct to 0 to disable that tier.
# Defaults shown.
# SLAUDE_TOKEN_WARN_PCT=0.8
# SLAUDE_TOKEN_CRITICAL_PCT=0.92

# --- /mcp OAuth connect (HTTP MCP servers, in /1on1 mode) ---
# Two modes for the authorization-code callback:
#
#   LOOPBACK (default, local / same-host container): unset SLAUDE_OAUTH_REDIRECT_URL.
#     slaude binds an ephemeral loopback listener; the initiator's browser must
#     reach it on the slaude host. SLAUDE_OAUTH_LOOPBACK_HOST=0.0.0.0 in-container.
#
#   PASTE-BACK (k8s / remote, no reachable loopback): set SLAUDE_OAUTH_REDIRECT_URL
#     to a STATIC page you host. The IdP redirects the browser there after auth;
#     the page should display the `code` (and `state`) with a "paste this back into
#     Slack" instruction. The initiator pastes the callback URL (or bare code) into
#     the locked thread and slaude finishes the exchange. No port, no ingress to
#     slaude required — only that one static page must be reachable by the user.
# SLAUDE_OAUTH_REDIRECT_URL=https://slaude.example.com/oauth/paste
# SLAUDE_OAUTH_LOOPBACK_HOST=127.0.0.1
# SLAUDE_OAUTH_LOOPBACK_PORTS=40100-40110

# --- External MCP servers ---
# Configured via ./data/.mcp.json (mounted into the container at /data/.mcp.json,
# which claude-code auto-discovers from the session cwd parent chain). Env vars
# below are referenced via ${VAR} substitution inside .mcp.json.
GRAFANA_URL=
GRAFANA_API_KEY=
