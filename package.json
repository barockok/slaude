{
  "name": "slaude",
  "version": "0.33.0",
  "type": "module",
  "private": true,
  "description": "Slack-native Claude Code runtime. Onboard AI agent as team member.",
  "author": "Zidni Mubarok <zidmubarock@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barockok/slaude.git"
  },
  "bugs": {
    "url": "https://github.com/barockok/slaude/issues"
  },
  "homepage": "https://github.com/barockok/slaude#readme",
  "main": "src/server.ts",
  "bin": {
    "slaude": "bin/slaude.ts"
  },
  "scripts": {
    "link": "chmod +x bin/slaude.ts && ln -sf \"$PWD/bin/slaude.ts\" \"$HOME/.bun/bin/slaude\" && echo linked: $HOME/.bun/bin/slaude",
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "sim": "bun src/gateway/sim/cli.ts",
    "typecheck": "tsc --noEmit",
    "manifest": "bun src/cli/manifest.ts",
    "validate-soul": "bun src/cli/validate.ts",
    "install-deps": "bun src/cli/install.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "brain-backfill": "bun src/cli/brain-backfill.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.173",
    "@anthropic-ai/sdk": "^0.104.1",
    "@opentui/core": "^0.3.2",
    "@opentui/react": "^0.3.2",
    "@slack/bolt": "^4.1.0",
    "gbrain": "github:garrytan/gbrain#03ffc6ebdbc7dd8b29e5bfd0c3a9a6c983b54f01",
    "react": "^19.2.7",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  }
}
